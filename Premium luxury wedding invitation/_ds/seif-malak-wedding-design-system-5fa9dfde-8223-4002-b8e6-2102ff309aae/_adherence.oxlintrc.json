{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/invitation/**",
              "ui_kits/invitation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bodoni Moda|Parisienne))/i]",
        "message": "Font not provided by the design system. Available: Bodoni Moda, Parisienne."
      },
      {
        "selector": "JSXOpeningElement[name.name='Botanical'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|src|height|opacity|style|key|ref|className|style|children)$/]",
        "message": "<Botanical> doesn't accept that prop. Declared props: variant, src, height, opacity, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Botanical'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:sprig|ornament)$/]",
        "message": "<Botanical> variant must be one of 'sprig' | 'ornament'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Countdown'] > JSXAttribute > JSXIdentifier[name!=/^(?:month|day|target|label|style|key|ref|className|style|children)$/]",
        "message": "<Countdown> doesn't accept that prop. Declared props: month, day, target, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DateBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:weekday|month|day|year|style|key|ref|className|style|children)$/]",
        "message": "<DateBlock> doesn't accept that prop. Declared props: weekday, month, day, year, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:ornament|width|style|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: ornament, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrameCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|ratio|maxWidth|style|key|ref|className|style|children)$/]",
        "message": "<FrameCard> doesn't accept that prop. Declared props: children, ratio, maxWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:venue|city|href|style|key|ref|className|style|children)$/]",
        "message": "<MapLink> doesn't accept that prop. Declared props: venue, city, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Monogram'] > JSXAttribute > JSXIdentifier[name!=/^(?:left|right|size|style|key|ref|className|style|children)$/]",
        "message": "<Monogram> doesn't accept that prop. Declared props: left, right, size, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Botanical": {
        "replaces": []
      },
      "Countdown": {
        "replaces": []
